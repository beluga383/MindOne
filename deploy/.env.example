# 复制为 deploy/.env 后再填写。不要提交 deploy/.env。
# 可用 `openssl rand -hex 32` 分别生成数据库 owner 密码、runtime 密码和 token pepper。
# 故意留空：Compose 的 `:?` 校验会阻止未替换的样例值启动生产栈。
MINDONE_POSTGRES_PASSWORD=
MINDONE_POSTGRES_APP_PASSWORD=
MINDONE_GITHUB_CLIENT_ID=
MINDONE_TOKEN_PEPPER=
# Standard payload/result 数据库静态保护独立密钥文件；先执行：
# install -m 0600 /dev/null deploy/secrets/standard-data-key
# openssl rand -hex 32 > deploy/secrets/standard-data-key
MINDONE_STANDARD_DATA_KEY_FILE=./secrets/standard-data-key
# 可选覆盖预构建的协调器镜像；质量运维 one-shot 必须复用完全相同的镜像。
MINDONE_COORDINATOR_IMAGE=mindone-coordinator:local
# 仅供 docker-compose.quality-operator.yml。两者必须是仓库外绝对目录；
# trusted-keys 放 `<evaluator_id>.pub` 公钥和短期签名
# `private-evaluation-catalog-v1.json`，签名私钥不得复制或挂载给协调器。
MINDONE_QUALITY_KEYS_HOST_DIR=
MINDONE_QUALITY_EVIDENCE_HOST_DIR=
# 仅供 private v2 quality overlay。必须是独立 Secret，不能复用 token pepper 或 Standard key。
# 文件严格为 `mindone-private-hidden-hmac-v1:<64 位小写 hex>\n`；建议仓库外绝对路径。
MINDONE_PRIVATE_EVALUATION_HMAC_KEY_HOST_FILE=
# 六项 private 抗耗尽预算没有生产默认值；启用 overlay 前必须逐项按容量评审明确填写。
# 四项 hourly limit 允许 1..4096；cooldown 允许 1..86400；reserve 允许 0..4095。
MINDONE_PRIVATE_EVALUATION_CATALOG_HOURLY_LIMIT=
MINDONE_PRIVATE_EVALUATION_ACCOUNT_HOURLY_LIMIT=
MINDONE_PRIVATE_EVALUATION_DEVICE_HOURLY_LIMIT=
MINDONE_PRIVATE_EVALUATION_NODE_HOURLY_LIMIT=
MINDONE_PRIVATE_EVALUATION_COOLDOWN_SECONDS=
MINDONE_PRIVATE_EVALUATION_GLOBAL_RESERVE_ENTRIES=
# 可选覆盖：普通 claim 每次以 1/N 概率混入精确实例挑战；生产允许 1..10000。
MINDONE_EVALUATION_DRAW_DENOMINATOR=8
# 同一模型实例的评价冷却秒数；生产允许 1..3600。
MINDONE_EVALUATION_INSTANCE_COOLDOWN_SECONDS=60
# 仅供 docker-compose.dev.yml；使用 URL-safe 随机值，不要与生产密码复用。
MINDONE_DEV_POSTGRES_PASSWORD=
# 仅供 docker-compose.dev.yml；`openssl rand -hex 32`，不得复用生产密钥。
MINDONE_DEV_STANDARD_DATA_KEY=
# 基础 Compose 的本机维护端口；公网 overlay 会完全移除该端口映射。
MINDONE_COORDINATOR_HOST_PORT=18787
# 仅在启用 docker-compose.cloudflared.yml 时填写；文件只含 Dashboard 提供的 connector token。
MINDONE_CLOUDFLARED_TOKEN_FILE=./secrets/cloudflared/token
RUST_LOG=mindone_coordinator=info,tower_http=info,sqlx=warn
